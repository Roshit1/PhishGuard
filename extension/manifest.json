{
  \"manifest_version\": 3,
  \"name\": \"PhishGuard\",
  \"version\": \"1.0\",
  \"description\": \"Detects and alerts you about phishing URLs in real-time.\",
  \"permissions\": [
    \"tabs\",
    \"storage\"
  ],
  \"host_permissions\": [
    \"<all_urls>\",
    \"http://localhost:8000/*\"
  ],
  \"background\": {
    \"service_worker\": \"background.js\"
  },
  \"content_scripts\": [
    {
      \"matches\": [\"<all_urls>\"],
      \"js\": [\"content.js\"],
      \"run_at\": \"document_start\"
    }
  ],
  \"action\": {
    \"default_popup\": \"popup.html\",
    \"default_title\": \"PhishGuard Status\"
  }
}
